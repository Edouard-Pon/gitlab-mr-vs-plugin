<UserControl x:Class="GitLabMr.Vsix.ToolWindows.MrToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">

    <!-- All control templates are hand-rolled on the CommonControlsColors palette (the same
         brushes the built-in Git tool window uses) so every state — normal, hover, pressed,
         disabled, focused — follows the active VS theme in both light and dark. -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ============ text styles (keyed, not implicit: implicit TextBlock styles
             would leak into control templates) ============ -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,4" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
        </Style>

        <!-- ============ TextBox ============ -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxTextBrushKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxBorderFocusedBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxBackgroundDisabledBrushKey}}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxBorderDisabledBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxTextDisabledBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ PasswordBox ============ -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxTextBrushKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bd" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.TextBoxBorderFocusedBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Button ============ -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBorderBrushKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonHoverBrushKey}}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBorderHoverBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonHoverTextBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonPressedBrushKey}}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBorderPressedBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonPressedTextBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonDisabledBrushKey}}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonBorderDisabledBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ButtonDisabledTextBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ CheckBox ============ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:CommonControlsColors.CheckBoxTextBrushKey}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="box" Width="16" Height="16" CornerRadius="3" BorderThickness="1"
                                    VerticalAlignment="Center" SnapsToDevicePixels="True"
                                    Background="{DynamicResource {x:Static vsui:CommonControlsColors.CheckBoxBackgroundBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static vsui:CommonControlsColors.CheckBoxBorderBrushKey}}">
                                <Path x:Name="glyph" Data="M 1 4.5 L 4.5 8 L 10.5 1.5" Margin="2"
                                      Stretch="Uniform" Visibility="Collapsed"
                                      StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Stroke="{DynamicResource {x:Static vsui:CommonControlsColors.CheckBoxGlyphBrushKey}}" />
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="7,0,0,0" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="glyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.CheckBoxBackgroundHoverBrushKey}}" />
                                <Setter TargetName="box" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.CheckBoxBorderHoverBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ ComboBox ============ -->
        <Style x:Key="ComboBoxEditableTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxTextBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxTextBrushKey}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False" Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxListItemTextBrushKey}}" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" CornerRadius="3" Margin="2,1" Padding="{TemplateBinding Padding}"
                                Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxListItemBackgroundHoverBrushKey}}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxListItemTextHoverBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxTextBrushKey}}" />
            <Setter Property="MaxDropDownHeight" Value="240" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="root" MinHeight="26">
                            <ToggleButton x:Name="toggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" CornerRadius="4" BorderThickness="1" SnapsToDevicePixels="True"
                                                Background="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxBackgroundBrushKey}}"
                                                BorderBrush="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxBorderBrushKey}}">
                                            <Path Data="M 0 0 L 4.5 4.5 L 9 0" StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,1,10,0"
                                                  Stroke="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxGlyphBrushKey}}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background"
                                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxBackgroundHoverBrushKey}}" />
                                                <Setter TargetName="bd" Property="BorderBrush"
                                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxBorderHoverBrushKey}}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush"
                                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxBorderFocusedBrushKey}}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="present" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,28,0" VerticalAlignment="Center" />

                            <TextBox x:Name="PART_EditableTextBox" Style="{StaticResource ComboBoxEditableTextBox}"
                                     Margin="7,1,28,1" VerticalContentAlignment="Center"
                                     Visibility="Collapsed" Focusable="True" />

                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" PopupAnimation="Slide"
                                   Focusable="False">
                                <Border CornerRadius="4" BorderThickness="1" Margin="0,3,0,0" SnapsToDevicePixels="True"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxListBackgroundBrushKey}}"
                                        BorderBrush="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxListBorderBrushKey}}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="present" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Expander (Win11-style chevron header) ============ -->
        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="hdr" Focusable="False"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="7,6"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="chev" Data="M 1 1 L 5.5 5.5 L 1 10"
                                                      StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      VerticalAlignment="Center" HorizontalAlignment="Left"
                                                      RenderTransformOrigin="0.5,0.5" Opacity="0.75"
                                                      Stroke="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                                                <ContentPresenter Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="chev" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background"
                                                        Value="{DynamicResource {x:Static vsui:CommonControlsColors.ComboBoxListItemBackgroundHoverBrushKey}}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="content" Visibility="Collapsed" Margin="27,4,0,6" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="content" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Card ============ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}" />
            <Setter Property="Padding" Value="10" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <!-- ============ Settings ============ -->
            <Expander x:Name="expSettings" IsExpanded="False">
                <Expander.Header>
                    <TextBlock Text="Settings — GitLab URL &amp; token" Style="{StaticResource SectionHeader}" />
                </Expander.Header>
                <StackPanel>
                    <TextBlock Text="GitLab base URL (e.g. https://gitlab.example.com)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="txtBaseUrl" />

                    <TextBlock Text="Personal Access Token (scope: api) — stored DPAPI-encrypted" Style="{StaticResource FieldLabel}" />
                    <PasswordBox x:Name="pwdToken" />
                    <TextBlock x:Name="lblTokenState" FontStyle="Italic" Style="{StaticResource Muted}" />

                    <CheckBox x:Name="chkIgnoreTls" Content="Ignore TLS certificate errors (dev only — trust the cert in Windows instead)"
                              Margin="0,10,0,0" />

                    <WrapPanel>
                        <Button x:Name="btnSaveSettings" Content="Save settings" Click="OnSaveSettings" Margin="0,10,8,0" />
                        <Button x:Name="btnTestConnection" Content="Test connection" Click="OnTestConnection" Margin="0,10,8,0" />
                    </WrapPanel>
                </StackPanel>
            </Expander>

            <!-- ============ Repo context ============ -->
            <Border Style="{StaticResource Card}" Margin="0,6,0,6">
                <StackPanel>
                    <TextBlock x:Name="lblContext" Text="No repository context yet." TextWrapping="Wrap" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                    <WrapPanel>
                        <Button x:Name="btnRefresh" Content="Refresh context" Click="OnRefreshContext" Margin="0,8,8,0" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ============ Create MR ============ -->
            <Expander x:Name="expCreate" IsExpanded="True">
                <Expander.Header>
                    <TextBlock Text="Create merge request" Style="{StaticResource SectionHeader}" />
                </Expander.Header>
                <StackPanel>
                    <StackPanel x:Name="pnlForm" IsEnabled="False">
                        <TextBlock Text="Title" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="txtTitle" />
                        <CheckBox x:Name="chkDraft" Content="Mark as draft" Margin="0,8,0,0" />

                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="txtDescription" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="90" VerticalScrollBarVisibility="Auto" />

                        <TextBlock Text="Target branch" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="cmbTargetBranch" IsEditable="True" />

                        <TextBlock Text="Assignee" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="cmbAssignee" />

                        <TextBlock Text="Reviewer (request review)" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="cmbReviewer" />

                        <CheckBox x:Name="chkDeleteSource" Content="Delete source branch when merged" IsChecked="True" Margin="0,12,0,0" />
                        <CheckBox x:Name="chkSquash" Content="Squash commits when merged" Margin="0,8,0,0" />

                        <WrapPanel>
                            <Button x:Name="btnCreate" Content="Create merge request" Click="OnCreateMr"
                                    FontWeight="SemiBold" Margin="0,12,8,0" />
                            <Button x:Name="btnClearForm" Content="Clear form" Click="OnClearForm" Margin="0,12,8,0"
                                    ToolTip="Reset all fields — e.g. after the MR is done or you switched branches" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- Created / current MR -->
                    <Border x:Name="pnlMr" Style="{StaticResource Card}" Margin="0,12,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="lblMrTitle" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                            <TextBlock x:Name="lblMrState" Style="{StaticResource Muted}" />
                            <WrapPanel>
                                <Button x:Name="btnApprove" Content="Approve" Click="OnApprove" Margin="0,8,8,0" />
                                <Button x:Name="btnMerge" Content="Merge" Click="OnMerge" Margin="0,8,8,0" />
                                <Button x:Name="btnRefreshMr" Content="Refresh state" Click="OnRefreshMr" Margin="0,8,8,0" />
                                <Button Content="Open in browser" Click="OnOpenMrDefault" Margin="0,8,1,0" />
                                <Button Content="&#x25BE;" Click="OnOpenMrMenu" Margin="0,8,8,0" Padding="7,5"
                                        ToolTip="Open in a specific browser" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Expander>

            <!-- ============ Open MRs of the project ============ -->
            <Expander x:Name="expMrList" IsExpanded="True">
                <Expander.Header>
                    <TextBlock x:Name="lblMrListHeader" Text="Open merge requests" Style="{StaticResource SectionHeader}" />
                </Expander.Header>
                <StackPanel>
                    <WrapPanel>
                        <Button x:Name="btnRefreshList" Content="Refresh list" Click="OnRefreshMrList" Margin="0,6,8,0" />
                    </WrapPanel>
                    <TextBlock x:Name="lblMrListEmpty" Text="No merge requests loaded yet." Style="{StaticResource Muted}" Margin="0,8,0,0" />

                    <ItemsControl x:Name="icMrs">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                                        <TextBlock Text="{Binding BranchInfo}" Opacity="0.7" TextWrapping="Wrap" Margin="0,4,0,0"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                                        <TextBlock Text="{Binding StateInfo}" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                                        <TextBlock Text="{Binding PeopleInfo}" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />

                                        <WrapPanel>
                                            <Button Content="Mark ready" Click="OnMrMarkReady" Margin="0,8,8,0"
                                                    ToolTip="Remove the draft status"
                                                    Visibility="{Binding CanMarkReady, Converter={StaticResource BoolToVis}}" />
                                            <Button Content="Approve" Click="OnMrApproveItem" Margin="0,8,8,0"
                                                    Visibility="{Binding CanApprove, Converter={StaticResource BoolToVis}}" />
                                            <Button Content="Merge" Click="OnMrMergeItem" Margin="0,8,8,0"
                                                    Visibility="{Binding CanMerge, Converter={StaticResource BoolToVis}}" />
                                            <Button Content="Open in browser" Click="OnMrOpenDefault" Margin="0,8,1,0" />
                                            <Button Content="&#x25BE;" Click="OnMrOpenMenu" Margin="0,8,8,0" Padding="7,5"
                                                    ToolTip="Open in a specific browser" />
                                        </WrapPanel>

                                        <TextBlock Text="Read-only: you are not a reviewer of this merge request."
                                                   FontStyle="Italic" Opacity="0.55" Margin="0,6,0,0" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                                   Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- ============ Status line ============ -->
            <Border Padding="2,8" Margin="0,8,0,0" BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}">
                <TextBlock x:Name="lblStatus" TextWrapping="Wrap" Opacity="0.85"
                           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
